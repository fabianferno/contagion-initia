# Initia appchain endpoints
VITE_INITIA_CHAIN_ID=contagion-1
VITE_INITIA_CHAIN_NAME=Contagion Appchain
VITE_INITIA_RPC_URL=http://localhost:26657
VITE_INITIA_REST_URL=http://localhost:1317
VITE_INITIA_INDEXER_URL=http://localhost:8080
VITE_INITIA_JSON_RPC_URL=http://localhost:8545
VITE_INITIA_GAS_DENOM=umin
VITE_INITIA_BECH32_PREFIX=init
VITE_INITIA_SYMBOL=MIN
VITE_INITIA_TOKEN_NAME=Contagion Token

# Bech32 address of the account that published contagion::attestations.
# Required for the auto-sign attestation flow to fire on-chain.
VITE_CONTAGION_MODULE_ADDRESS=

# Client runtime
VITE_GAME_TITLE=Contagion
VITE_GAME_TAGLINE=Trust No One
VITE_CONTAGION_WS_URL=

# Public faucet shown as a fallback in the FaucetModal if the in-app
# faucet fails or isn't configured. Read by both the client (Vite) and
# the server (so /api/faucet errors include the URL in their response).
VITE_PUBLIC_FAUCET_URL=

# In-app faucet (server-side). The server signs a MsgSend with this
# mnemonic via @initia/initia.js and broadcasts to VITE_INITIA_REST_URL.
# Leave FAUCET_MNEMONIC blank if you only want the public faucet fallback.
# The mnemonic NEVER leaves the server.
FAUCET_MNEMONIC=
FAUCET_AMOUNT=5000000umin
FAUCET_GAS_PRICES=0.015umin
FAUCET_GAS_ADJUSTMENT=1.5
# Defaults to VITE_INITIA_CHAIN_ID if unset:
# FAUCET_CHAIN_ID=
